{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://example.com/schemas/contribution-artifact.json",
  "title": "Cold-Chain Freight Monte Carlo Contribution Artifact",
  "description": "Schema for Monte Carlo simulation contribution artifacts ensuring reproducibility and validation",
  "type": "object",
  "required": [
    "simulation_id",
    "timestamp",
    "parameters",
    "base_seed",
    "n_chunks",
    "chunk_size",
    "total_samples",
    "summary_statistics",
    "reproducibility_hash"
  ],
  "properties": {
    "simulation_id": {
      "type": "string",
      "description": "Unique identifier for this simulation run (MD5 hash of parameters and seed)",
      "pattern": "^[a-f0-9]{32}$"
    },
    "timestamp": {
      "type": "string",
      "description": "ISO 8601 timestamp of simulation completion",
      "format": "date-time"
    },
    "parameters": {
      "type": "object",
      "description": "Input parameters used for the simulation",
      "required": [
        "distance_mean",
        "distance_sd",
        "payload_mean",
        "payload_sd",
        "temp_mean",
        "temp_sd",
        "fuel_efficiency_mean",
        "fuel_efficiency_sd",
        "refrigeration_prob"
      ],
      "properties": {
        "distance_mean": {
          "type": "number",
          "minimum": 0,
          "maximum": 10000,
          "description": "Mean distance in kilometers"
        },
        "distance_sd": {
          "type": "number",
          "minimum": 0,
          "description": "Standard deviation of distance"
        },
        "payload_mean": {
          "type": "number",
          "minimum": 0,
          "maximum": 50,
          "description": "Mean payload in metric tons"
        },
        "payload_sd": {
          "type": "number",
          "minimum": 0,
          "description": "Standard deviation of payload"
        },
        "temp_mean": {
          "type": "number",
          "minimum": -40,
          "maximum": 50,
          "description": "Mean ambient temperature in Celsius"
        },
        "temp_sd": {
          "type": "number",
          "minimum": 0,
          "description": "Standard deviation of temperature"
        },
        "fuel_efficiency_mean": {
          "type": "number",
          "minimum": 10,
          "maximum": 100,
          "description": "Mean fuel efficiency in liters per 100km"
        },
        "fuel_efficiency_sd": {
          "type": "number",
          "minimum": 0,
          "description": "Standard deviation of fuel efficiency"
        },
        "refrigeration_prob": {
          "type": "number",
          "minimum": 0,
          "maximum": 1,
          "description": "Probability of refrigerated transport"
        }
      }
    },
    "base_seed": {
      "type": "integer",
      "description": "Base random seed for reproducibility"
    },
    "n_chunks": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of chunks used in distributed simulation"
    },
    "chunk_size": {
      "type": "integer",
      "minimum": 1,
      "description": "Number of samples per chunk"
    },
    "total_samples": {
      "type": "integer",
      "minimum": 1,
      "description": "Total number of Monte Carlo samples"
    },
    "summary_statistics": {
      "type": "object",
      "description": "Aggregated summary statistics from simulation",
      "required": [
        "total_samples",
        "n_dry",
        "n_refrigerated",
        "overall_mean_co2",
        "overall_sd_co2"
      ],
      "properties": {
        "total_samples": {
          "type": "integer",
          "minimum": 1
        },
        "n_dry": {
          "type": "integer",
          "minimum": 0
        },
        "n_refrigerated": {
          "type": "integer",
          "minimum": 0
        },
        "overall_mean_co2": {
          "type": "number"
        },
        "overall_sd_co2": {
          "type": "number",
          "minimum": 0
        },
        "overall_variance": {
          "type": "number",
          "minimum": 0
        },
        "dry_mean_co2": {
          "type": "number"
        },
        "dry_sd_co2": {
          "type": "number",
          "minimum": 0
        },
        "refrig_mean_co2": {
          "type": "number"
        },
        "refrig_sd_co2": {
          "type": "number",
          "minimum": 0
        },
        "dry_mean_cost": {
          "type": "number"
        },
        "refrig_mean_cost": {
          "type": "number"
        },
        "cost_difference": {
          "type": "number"
        }
      }
    },
    "reproducibility_hash": {
      "type": "string",
      "description": "MD5 hash of reproducibility context",
      "pattern": "^[a-f0-9]{32}$"
    },
    "metadata": {
      "type": "object",
      "description": "Optional metadata about the simulation",
      "properties": {
        "contributor": {
          "type": "string"
        },
        "institution": {
          "type": "string"
        },
        "notes": {
          "type": "string"
        }
      }
    }
  }
}
