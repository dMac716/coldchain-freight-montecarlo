linters: lintr::linters_with_defaults(line_length_linter = lintr::line_length_linter(120), object_usage_linter = lintr::object_usage_linter(), absolute_path_linter = lintr::absolute_path_linter(), commented_code_linter = lintr::commented_code_linter())
exclusions: list("docs" = ".*", "docs/site_libs" = ".*")
